# =============================================================================
# ENVIRONMENT SELECTION
# =============================================================================
APP_ENV=dev

# =============================================================================
# SECRET MANAGEMENT STRATEGY
# =============================================================================
# Never commit real secrets. For each environment use one of these patterns:
# 1) Local dev: .env (gitignored) loaded from this template.
# 2) QA/Prod in CI/CD: inject secrets from Vault, AWS Secrets Manager, GCP Secret
#    Manager or Doppler into runtime env vars.
# 3) Kubernetes: mount secrets as env vars or files and map to values below.
#
# Optional references (metadata only):
DEV_SECRETS_REF=vault://kv/health-platform/dev
QA_SECRETS_REF=vault://kv/health-platform/qa
PROD_SECRETS_REF=vault://kv/health-platform/prod

# =============================================================================
# SHARED DEFAULTS
# =============================================================================
API_PORT=3000
POSTGRES_PORT=5432
REDIS_PORT=6379
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# DEVELOPMENT (APP_ENV=dev)
# =============================================================================
DEV_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/health_platform_dev
DEV_REDIS_URL=redis://localhost:6379
DEV_POSTGRES_USER=postgres
DEV_POSTGRES_PASSWORD=postgres
DEV_POSTGRES_DB=health_platform_dev
DEV_MINIO_ROOT_USER=minioadmin
DEV_MINIO_ROOT_PASSWORD=minioadmin
DEV_MINIO_BUCKET=clinical-documents-dev
DEV_JWT_PRIVATE_KEY_PATH=./secrets/dev/jwt-private.pem
DEV_JWT_PUBLIC_KEY_PATH=./secrets/dev/jwt-public.pem
DEV_MERCADO_PAGO_ACCESS_TOKEN=replace-me
DEV_MERCADO_PAGO_WEBHOOK_SECRET=replace-me
DEV_OTP_PROVIDER_API_KEY=replace-me
DEV_EMAIL_PROVIDER_API_KEY=replace-me
DEV_PUSH_PROVIDER_API_KEY=replace-me
DEV_LEGACY_API_BASE_URL=https://legacy-dev.example.com
DEV_LEGACY_API_KEY=replace-me
DEV_LAB_API_BASE_URL=https://lab-dev.example.com
DEV_LAB_API_KEY=replace-me
DEV_RIS_PACS_API_BASE_URL=https://rispacs-dev.example.com
DEV_RIS_PACS_API_KEY=replace-me

# =============================================================================
# QA (APP_ENV=qa)
# =============================================================================
QA_DATABASE_URL=postgresql://qa_user:replace-me@qa-postgres:5432/health_platform_qa
QA_REDIS_URL=redis://qa-redis:6379
QA_POSTGRES_USER=qa_user
QA_POSTGRES_PASSWORD=replace-me
QA_POSTGRES_DB=health_platform_qa
QA_MINIO_ROOT_USER=qa-minio
QA_MINIO_ROOT_PASSWORD=replace-me
QA_MINIO_BUCKET=clinical-documents-qa
QA_JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt-private.pem
QA_JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt-public.pem
QA_MERCADO_PAGO_ACCESS_TOKEN=replace-me
QA_MERCADO_PAGO_WEBHOOK_SECRET=replace-me
QA_OTP_PROVIDER_API_KEY=replace-me
QA_EMAIL_PROVIDER_API_KEY=replace-me
QA_PUSH_PROVIDER_API_KEY=replace-me
QA_LEGACY_API_BASE_URL=https://legacy-qa.example.com
QA_LEGACY_API_KEY=replace-me
QA_LAB_API_BASE_URL=https://lab-qa.example.com
QA_LAB_API_KEY=replace-me
QA_RIS_PACS_API_BASE_URL=https://rispacs-qa.example.com
QA_RIS_PACS_API_KEY=replace-me

# =============================================================================
# PRODUCTION (APP_ENV=prod)
# =============================================================================
PROD_DATABASE_URL=postgresql://prod_user:replace-me@prod-postgres:5432/health_platform_prod
PROD_REDIS_URL=redis://prod-redis:6379
PROD_POSTGRES_USER=prod_user
PROD_POSTGRES_PASSWORD=replace-me
PROD_POSTGRES_DB=health_platform_prod
PROD_MINIO_ROOT_USER=prod-minio
PROD_MINIO_ROOT_PASSWORD=replace-me
PROD_MINIO_BUCKET=clinical-documents
PROD_JWT_PRIVATE_KEY_PATH=/var/run/secrets/jwt-private.pem
PROD_JWT_PUBLIC_KEY_PATH=/var/run/secrets/jwt-public.pem
PROD_MERCADO_PAGO_ACCESS_TOKEN=replace-me
PROD_MERCADO_PAGO_WEBHOOK_SECRET=replace-me
PROD_OTP_PROVIDER_API_KEY=replace-me
PROD_EMAIL_PROVIDER_API_KEY=replace-me
PROD_PUSH_PROVIDER_API_KEY=replace-me
PROD_LEGACY_API_BASE_URL=https://legacy.example.com
PROD_LEGACY_API_KEY=replace-me
PROD_LAB_API_BASE_URL=https://lab.example.com
PROD_LAB_API_KEY=replace-me
PROD_RIS_PACS_API_BASE_URL=https://rispacs.example.com
PROD_RIS_PACS_API_KEY=replace-me

# =============================================================================
# RUNTIME VARIABLES (resolved at deploy time)
# =============================================================================
DATABASE_URL=${DEV_DATABASE_URL}
REDIS_URL=${DEV_REDIS_URL}
POSTGRES_USER=${DEV_POSTGRES_USER}
POSTGRES_PASSWORD=${DEV_POSTGRES_PASSWORD}
POSTGRES_DB=${DEV_POSTGRES_DB}
MINIO_ROOT_USER=${DEV_MINIO_ROOT_USER}
MINIO_ROOT_PASSWORD=${DEV_MINIO_ROOT_PASSWORD}
MERCADO_PAGO_ACCESS_TOKEN=${DEV_MERCADO_PAGO_ACCESS_TOKEN}
MERCADO_PAGO_WEBHOOK_SECRET=${DEV_MERCADO_PAGO_WEBHOOK_SECRET}
LEGACY_API_BASE_URL=${DEV_LEGACY_API_BASE_URL}
LEGACY_API_KEY=${DEV_LEGACY_API_KEY}
LAB_API_BASE_URL=${DEV_LAB_API_BASE_URL}
LAB_API_KEY=${DEV_LAB_API_KEY}
RIS_PACS_API_BASE_URL=${DEV_RIS_PACS_API_BASE_URL}
RIS_PACS_API_KEY=${DEV_RIS_PACS_API_KEY}
OTP_PROVIDER_API_KEY=${DEV_OTP_PROVIDER_API_KEY}
EMAIL_PROVIDER_API_KEY=${DEV_EMAIL_PROVIDER_API_KEY}
PUSH_PROVIDER_API_KEY=${DEV_PUSH_PROVIDER_API_KEY}
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
