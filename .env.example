# =============================
# Global
# =============================
NODE_ENV=development
TZ=America/Argentina/Buenos_Aires
APP_NAME=clinica
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# =============================
# Database / Cache
# =============================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/clinicadb?schema=public
REDIS_URL=redis://localhost:6379

# =============================
# Auth / Identity
# =============================
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000
OTP_PROVIDER=console
OTP_TTL_SECONDS=300
OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_MIN_LENGTH=8

# =============================
# External messaging
# =============================
SMS_PROVIDER=mock
SMS_BASE_URL=
SMS_API_KEY=
SMTP_URL=smtp://user:pass@mailhog:1025
SMTP_FROM=no-reply@buenpastor.com.ar
PUSH_PROVIDER=expo
PUSH_ACCESS_TOKEN=

# =============================
# Object storage (S3 compatible)
# =============================
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minio
S3_SECRET_KEY=minio123
S3_BUCKET=clinical-documents
S3_PUBLIC_BASE_URL=http://localhost:9000
SIGNED_URL_TTL_SECONDS=300

# =============================
# Payments (Mercado Pago)
# =============================
MERCADO_PAGO_ACCESS_TOKEN=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
MERCADO_PAGO_WEBHOOK_SECRET=replace-webhook-secret
MERCADO_PAGO_WEBHOOK_URL=http://localhost:4000/payments/webhooks/mercado-pago
PAYMENTS_SANDBOX_MODE=true

# =============================
# Scheduling & business rules
# =============================
SLOT_HOLD_TTL_SECONDS=600
MAX_ACTIVE_BOOKINGS_PER_PATIENT=3
CANCELLATION_WINDOW_HOURS=24
RESCHEDULE_WINDOW_HOURS=24

# =============================
# Integrations: legacy and clinical ecosystem
# =============================
LEGACY_API_URL=http://localhost:4010
LEGACY_API_KEY=legacy-dev-key
OPENMEDICA_API_URL=http://localhost:4011
OPENMEDICA_API_KEY=openmedica-dev-key
LAB_API_URL=http://localhost:4012
LAB_API_KEY=lab-dev-key
RIS_PACS_API_URL=http://localhost:4013
RIS_PACS_API_KEY=rispacs-dev-key
PADRON_API_URL=http://localhost:4014
PADRON_API_KEY=padron-dev-key
INTEGRATION_TIMEOUT_MS=8000
INTEGRATION_MAX_RETRIES=3
INTEGRATION_RETRY_DELAY_MS=500

# =============================
# Observability
# =============================
LOG_LEVEL=debug
ENABLE_REQUEST_LOGGING=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
SENTRY_DSN=
PROMETHEUS_ENABLED=true

# =============================
# Mobile app (Expo) - public runtime vars
# =============================
EXPO_PUBLIC_API_URL=http://localhost:4000
EXPO_PUBLIC_APP_ENV=dev
EXPO_PUBLIC_MERCADO_PAGO_PUBLIC_KEY=TEST-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
EXPO_PUBLIC_ENABLE_BIOMETRICS=true

# =============================
# Admin web (Next.js)
# =============================
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_APP_ENV=dev
ADMIN_SESSION_SECRET=change-me-admin-secret
